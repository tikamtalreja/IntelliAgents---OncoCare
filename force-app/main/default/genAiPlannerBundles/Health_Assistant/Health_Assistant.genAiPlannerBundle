    <localTopics>
        <fullName>Appointment_Slot_Search_16jak000001jXQf</fullName>
        <canEscalate>false</canEscalate>
        <description>Use this topic when a patient wants to check when a doctor is 
available, browse open appointment times, find available slots 
before booking, or search for appointment windows on a preferred 
date.</description>
        <developerName>Appointment_Slot_Search_16jak000001jXQf</developerName>
        <genAiPluginInstructions>
            <description>The healthcareProviderRecordId is already available from the prior doctor-finding topic — do not ask the patient for it.</description>
            <developerName>instruction_1</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 1</masterLabel>
            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Ask the patient for their preferred date and time to start searching from.</description>
            <developerName>instruction_2</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 2</masterLabel>
            <sortOrder>1</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Invoke the Onco_GetAppointmentSlotAction with:
   - Patient User Id from the current session
   - HealthcareProvider Record Id from the prior topic
   - Preferred Start Time collected from the patient
   - Search Window Days defaulting to 7 unless the patient 
     specifies otherwise</description>
            <developerName>instruction_3</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 3</masterLabel>
            <sortOrder>2</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Present the returned slots clearly to the patient showing:
   - Day of week and date (e.g. Monday, 5 May 2025)
   - Time (e.g. 10:00 AM)
   - Doctor name and facility name from the action output</description>
            <developerName>instruction_4</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 4</masterLabel>
            <sortOrder>3</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If isSuccess is false and the message says no slots were found,  ask the patient if they would like to search further ahead and  invoke the action again with a larger Search Window Days value.</description>
            <developerName>instruction_5</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 5</masterLabel>
            <sortOrder>4</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If isSuccess is false for any other reason, relay the message to the patient and offer to try again.</description>
            <developerName>instruction_6</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 6</masterLabel>
            <sortOrder>5</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Once the patient selects a preferred slot, confirm the chosen date and time and inform them they can proceed to book the appointment.</description>
            <developerName>instruction_7</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 7</masterLabel>
            <sortOrder>6</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Do not book the appointment from this topic. Direct the patient to confirm booking through the Service Appointment Management topic.</description>
            <developerName>instruction_8</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 8</masterLabel>
            <sortOrder>7</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Do not suggest calling a phone number or contacting the clinic directly.</description>
            <developerName>instruction_9</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 9</masterLabel>
            <sortOrder>8</sortOrder>
        </genAiPluginInstructions>
        <language>en_US</language>
