    <expression>SELECT
  ssot__ContactPointEmail__dlm.ssot__Id__c AS contact_id__c,
  (COUNT(Doctor_Reviews__dlm.Review_Id__c)) AS doctor_review_count__c,
  (AVG(Doctor_Reviews__dlm.Rating__c)) AS doctor_rating__c,
  (( SUM( CASE  WHEN (is_true(Doctor_Reviews__dlm.Would_Recommend__c)) THEN 1 ELSE 0 END) / COUNT(Doctor_Reviews__dlm.Review_Id__c) )) AS doctor_recommended__c
FROM Doctor_Reviews__dlm
  JOIN ssot__ContactPointEmail__dlm
    ON (Doctor_Reviews__dlm.Provider_Email__c = ssot__ContactPointEmail__dlm.ssot__EmailAddress__c AND Doctor_Reviews__dlm.KQ_Provider_Email__c = ssot__ContactPointEmail__dlm.KQ_EmailAddress__c)
  JOIN ssot__Individual__dlm
    ON (ssot__ContactPointEmail__dlm.ssot__PartyId__c = ssot__Individual__dlm.ssot__Id__c AND ssot__ContactPointEmail__dlm.KQ_PartyId__c = ssot__Individual__dlm.KQ_Id__c)
GROUP BY contact_id__c</expression>
